# Contact form (Resend)
# Get a key at https://resend.com → drop it in .env.local
RESEND_API_KEY=
# Email the contact form sends to. Defaults to yashveersr4@gmail.com.
CONTACT_TO_EMAIL=yashveersr4@gmail.com
# Verified "from" address on Resend. Falls back to onboarding@resend.dev during dev.
CONTACT_FROM_EMAIL=

# Canonical site URL (used by sitemap + JSON-LD)
SITE_URL=https://yashveerlabs.vercel.app
